# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/legacystudio?retryWrites=true&w=majority
MONGODB_DB=legacystudio

# Cloudinary credentials (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Auth
JWT_SECRET=replace_with_a_long_random_string
# Initial admin account (created by `npm run seed`)
ADMIN_EMAIL=admin@mylegacystudio.com
ADMIN_PASSWORD=change_me
